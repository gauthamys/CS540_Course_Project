# ============================================================================
# LLM Configuration
# ============================================================================

# Use local Ollama instead of Claude API (true or false)
# - true: Use local model (Mistral Nemo) via Ollama
# - false: Use Claude API via Anthropic
USE_LOCAL_LLM=true

# Local model to use (when USE_LOCAL_LLM=true)
# Options: mistral-nemo, mistral, llama2, etc.
# Make sure the model is pulled in Ollama: ollama pull mistral-nemo
LOCAL_MODEL_ID=mistral-nemo

# Ollama server URL (where Ollama is running)
# Default: http://localhost:11434 (if running locally)
OLLAMA_BASE_URL=http://localhost:11434

# Claude API key (only needed if USE_LOCAL_LLM=false)
# Get key from: https://console.anthropic.com/account/keys
# ANTHROPIC_API_KEY=sk-ant-v0-...

# ============================================================================
# Budget & Constraints (prevents runaway loops)
# ============================================================================

# Max LLM calls per task
MAX_LLM_CALLS_PER_TASK=10

# Max tokens per task
MAX_TOKENS_PER_TASK=8000

# Max repair iterations for code generation
MAX_REPAIR_ITERATIONS=3

# ============================================================================
# RE Elicitation Configuration
# ============================================================================

# Max iterations for RE elicitation revision loop
RE_MAX_ITERATIONS=3

# Semantic similarity threshold for RE evaluation (0.0 to 1.0)
# Higher = stricter matching (0.60 is default)
RE_SIM_THRESHOLD=0.6

# ============================================================================
# Reproducibility
# ============================================================================

# Random seed for dataset splits
RANDOM_SEED=42
